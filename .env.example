# ==========================================
# Schumaker Flow — Environment Configuration
# ==========================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/schumaker_flow?schema=public"

# Auth - JWT Secret (generate a strong random string)
JWT_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_STRING_AT_LEAST_32_CHARS"
JWT_EXPIRES_IN="7d"

# Google Drive - Service Account
GOOGLE_SERVICE_ACCOUNT_JSON=""
# OR path to the JSON file:
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH="./google-service-account.json"

# Mercado Pago - PIX Integration
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# Email / SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@schumakerflow.com"

# Application
BASE_URL="http://localhost:3000"
TENANT_DOMAIN="localhost" # In production: schumakerflow.com
NODE_ENV="development"

# Cron Secret (for securing cron API routes)
CRON_SECRET="CHANGE_ME_TO_A_RANDOM_STRING"
